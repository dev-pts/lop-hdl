module: test
	local:
		a: net

	for: i < 32
		a = i
		a = i + 1
		a = i - 1
		a = i < 15
		a = i > 15
		a = i * 15
		a = i >> 3
		a = i << 3
		a = i / 2
		a = i % 2
		a = i == 2
		a = i != 2
		a = i**2
		a = i | 3
		a = i & 3
		a = i && 3
		a = i || 3
		a = $clog2(i + 1)
		a = $int(i / 2)
		a = $round(i / 2)
		a = $floor(i / 2)
		a = $ceil(i / 2)
		a = $max(i, 15)
		a = $min(i, 15)
		a = -i
		a = -(i / 2)
		a = +(i / 2)
