interface: Interface
	port: Master / Slave
		a: net: out / in
		b: net[2]: in / out

module: SubModule
	port:
		e: Interface.Master
		f: Interface.Slave
		g[2]: Interface.Master
		h[2]: Interface.Slave
		i: out
		j[2]: out[3]

module: test
	port:
		a: Interface.Master
		b: Interface.Slave
		c[2]: Interface.Slave
		k: out
		l[2]: out[3]
	local:
		d: SubModule
		e[2]: SubModule

	a.a = a.b[0]

	for: i
		c[0].b[i] = b.a
	for: i
		c[i].b[0] = b.a
	for: i
		b.b[i] = c[0].a
	for: i
		b.b[i] = c[i].a

	for: i
		$connect(a, c[i])

	$connect(b, d.f)
	$connect(d.e, d.f)
	$connect(d.f, d.e)
	$connect(e[0].e, e[1].f)
	$connect(e[0].g[0], e[1].h[1])
