module: test
	port:
		a: out
		b[2]: out
		c: out[3]
		d[2]: out[3]

	a = 0

	b[0] = 1
	b[1] = 1
	for: i
		b[i] = i

	c[0] = 2
	c[1] = 2
	c[2] = 2
	for: i
		c[i] = i

	d[0] = 3
	d[1] = 3
	for: i
		d[i] = i

	d[0][0] = 3
	d[0][1] = 3
	d[0][2] = 3
	d[1][0] = 3
	d[1][1] = 3
	d[1][2] = 3

	for: i
		d[i][0] = i
		d[i][1] = i
		d[i][2] = i

	for: i
		d[0][i] = i
		d[1][i] = i

	for: i < 2
		for: j
			d[i][j] = i + j
